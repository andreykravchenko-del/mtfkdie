    - target: {fileID: 6505220537368002073, guid: 8c2cb8dfa427aad03bff4e77566102a8, type: 3}
      propertyPath: m_text
      value: "\u042F \u0441\u043C\u043E\u0442\u0440\u044E \u043D\u0430 \u0441\u0432\u043E\u0438
        \u0440\u0443\u043A\u0438 \u2014 \u043E\u043D\u0438 \u0431\u043E\u043B\u044C\u0448\u0435
        \u043D\u0435 \u0434\u0440\u043E\u0436\u0430\u0442, \u043F\u043E\u0442\u043E\u043C\u0443
        \u0447\u0442\u043E \u0432 \u044D\u0442\u043E\u043C \u043D\u0435\u0442 \u043D\u0443\u0436\u0434\u044B.
        \u041C\u043D\u0435 \u0441\u0442\u0430\u043B\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u043E
        \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E. \r\n\u042F \u0434\u0435\u043B\u0430\u044E
        \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0432\u0434\u043E\u0445,
        \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u043D\u0435\u0442 \u0434\u0430\u0436\u0435
        \u043A\u0430\u043F\u043B\u0438 \u043D\u0430\u0434\u0435\u0436\u0434\u044B,
        \u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E \u0442\u044F\u0436\u0435\u0441\u0442\u0438
        \u044D\u0442\u043E\u0433\u043E \u043C\u0438\u0440\u0430 \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
        \u043F\u0440\u0438\u0436\u0430\u0442\u044C \u043C\u0435\u043D\u044F \u043A
        \u043F\u043E\u043B\u0443. \u0422\u044B \u0431\u044B\u043B \u043F\u0440\u0430\u0432.
        \u0421\u0430\u043C\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u043E\u0442\u043F\u0443\u0441\u0442\u0438\u0442\u044C.
        \u0417\u0434\u0435\u0441\u044C \u0431\u0443\u0434\u0435\u0442 \u043B\u0443\u0447\u0448\u0435...
        \u0431\u0435\u0437 \u043C\u0435\u043D\u044F. \u041C\u043D\u0435 \u0431\u0443\u0434\u0435\u0442
        \u043B\u0443\u0447\u0448\u0435."
      objectReference: {fileID: 0}

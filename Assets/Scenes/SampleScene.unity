--- !u!114 &366036113
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 366036112}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1e2c5586d0d778c4089734c03ffee176, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  flyCamera: {fileID: 330585545}
  waypoints:
  - {fileID: 2113774408}
  - {fileID: 1265913228}
  - {fileID: 1802210266}
  moveDuration: 3.5
  holdDuration: 1.5
  skippable: 1
  playOnStart: 1
  introLines:
  - "\u041E\u0431\u0435\u0449\u0430\u043B \u0441\u0435\u0431\u0435 \u043B\u0435\u0447\u044C
    \u0441\u043F\u0430\u0442\u044C \u0432 \u0442\u043E\u0442 \u0436\u0435 \u0434\u0435\u043D\u044C,
    \u0447\u0442\u043E \u0438 \u043F\u0440\u043E\u0441\u043D\u0443\u043B\u0441\u044F,
    \u043D\u043E...\u043E\u043F\u044F\u0442\u044C \u043E\u043F\u043E\u0437\u0434\u0430\u043B. "
  - "\u042F \u0431\u0443\u0434\u0442\u043E \u0432 \u0442\u044E\u0440\u044C\u043C\u0435,
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043C\u043E\u0433\u0443
    \u0432\u044B\u0439\u0442\u0438, \u043D\u043E... \u043D\u0435 \u0445\u043E\u0447\u0443?
    \u0417\u0434\u0435\u0441\u044C \u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0441\u043A\u043E\u043B\u043A\u043E\u0432
    \u043F\u0440\u043E\u0448\u043B\u043E\u0433\u043E. \u041E\u0441\u043A\u043E\u043B\u043A\u043E\u0432
    \u0442\u043E\u0433\u043E, \u043A\u0435\u043C \u044F \u0431\u044B\u043B..."
  - "\u041F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u0434\u0435\u0440\u0436\u0430\u0442\u044C\u0441\u044F
    \u0437\u0430 \u044D\u0442\u0438 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F...
    \u0441\u0442\u0430\u0442\u044C \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u043E\u043D\u0435\u0440\u043E\u043C
    \u043C\u0435\u0440\u0442\u0432\u044B\u0445 \u0431\u0430\u0431\u043E\u0447\u0435\u043A.
    \u0418\u043D\u043E\u0433\u0434\u0430 \u043C\u043D\u0435 \u043A\u0430\u0436\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u044F \u043D\u0430\u0448\u0435\u043B \u0447\u0442\u043E-\u0442\u043E
    \u0445\u043E\u0440\u043E\u0448\u0435\u0435\u2026"
  - "\u0418 \u043C\u043D\u0435 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
    \u0441\u0442\u0440\u0430\u0448\u043D\u043E. \u0421\u0442\u0440\u0430\u0448\u043D\u043E,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0435
    \u2014 \u043B\u043E\u0436\u044C. \u0427\u0442\u043E \u0437\u0430 \u043D\u0438\u043C
    \u2014 \u0442\u043E\u043B\u044C\u043A\u043E \u0435\u0449\u0435 \u0431\u043E\u043B\u044C\u0448\u0430\u044F
    \u043F\u0443\u0441\u0442\u043E\u0442\u0430. "
  - "\u041F\u043E\u0441\u043C\u043E\u0442\u0440\u0438 \u043D\u0430 \u0441\u0435\u0431\u044F.
    \u0422\u044B \u2014 \u044D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0431\u043E\u0440
    \u043F\u044B\u043B\u044C\u043D\u044B\u0445 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0439
    \u0432 \u043F\u0443\u0441\u0442\u043E\u0439 \u043A\u043E\u0440\u043E\u0431\u043A\u0435."
  - "\u041C\u043E\u0436\u0435\u0442, \u0432\u0441\u0435-\u0442\u0430\u043A\u0438
    \u0441\u0434\u043E\u0445\u043D\u0435\u0448\u044C? \u0422\u044B \u0432\u0435\u0434\u044C
    \u0437\u043D\u0430\u0435\u0448\u044C, \u0447\u0442\u043E \u044D\u0442\u043E\u043C\u0443
    \u043C\u0438\u0440\u0443 \u0431\u0443\u0434\u0435\u0442 \u043B\u0443\u0447\u0448\u0435
    \u0431\u0435\u0437 \u0442\u0435\u0431\u044F? \u041C\u044B \u043E\u0431\u0430
    \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u043C \u044D\u0442\u043E."
  - "\u0420\u0443\u043A\u0438 \u043D\u0435 \u0437\u0430\u0436\u0438\u043B\u0438 \u0435\u0449\u0435
    \u0441 \u043F\u0440\u043E\u0448\u043B\u043E\u0433\u043E \u0440\u0430\u0437\u0430,
    \u0445\u0432\u0430\u0442\u0438\u0442!"
  introMusic: {fileID: 0}

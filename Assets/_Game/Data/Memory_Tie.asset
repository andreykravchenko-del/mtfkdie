  captureComments:
  - "\u041E\u043F\u044F\u0442\u044C \u043D\u0430 \u0448\u0435\u044E."
  - "\u041E\u043D \u0434\u0443\u0448\u0438\u0442."
  memoryImage: {fileID: 21300000, guid: 2f9364df0333c2c4795bbe8ba694d10e, type: 3}
  memoryText: "(\u0428\u0435\u043F\u043E\u0442\u043E\u043C) \u0421\u043C\u043E\u0442\u0440\u0438\u0448\u044C
    \u043D\u0430 \u043D\u0435\u0433\u043E \u0438 \u0441\u043A\u0443\u0447\u0430\u0435\u0448\u044C,
    \u0434\u0430? \u041F\u043E \u0431\u043E\u043B\u0438? \u041F\u043E \u0431\u0435\u0441\u043F\u043E\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0438?
    \u0422\u044B \u0434\u0430\u0436\u0435 \u043D\u0435 \u043C\u043E\u0436\u0435\u0448\u044C
    \u043F\u0440\u0438\u0437\u043D\u0430\u0442\u044C\u0441\u044F, \u0447\u0442\u043E
    \u0432 \u0433\u043B\u0443\u0431\u0438\u043D\u0435 \u0434\u0443\u0448\u0438 \u0442\u0435\u0431\u0435
    \u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F \u0440\u043E\u043B\u044C \u0436\u0435\u0440\u0442\u0432\u044B."

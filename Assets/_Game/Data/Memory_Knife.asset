  captureComments:
  - "\u041F\u0440\u0438\u0433\u043E\u0434\u0438\u0442\u0441\u044F."
  - "\u041C\u0435\u043B\u043E\u0447\u044C, \u0430 \u043D\u0443\u0436\u043D\u0430\u044F."
  - "\u0412\u0435\u0440\u0445\u043D\u0435\u0435 \u043B\u0435\u0437\u0432\u0438\u0435
    \u0441\u043E\u0432\u0441\u0435\u043C \u0437\u0430\u0442\u0443\u043F\u0438\u043B\u043E\u0441\u044C."
  memoryImage: {fileID: 21300000, guid: 84e0e85ef313c33459e6883a4ddf9025, type: 3}
  memoryText: "\u0421\u043B\u0435\u0434\u044B \u043A\u043B\u0435\u044F \u043D\u0430
    \u0440\u0443\u0447\u043A\u0435 \u043D\u043E\u0436\u0430 \u2014 \u0432\u0441\u0451,
    \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u043E\u0442
    \u0442\u0435\u0445 \u0434\u043D\u0435\u0439, \u043A\u043E\u0433\u0434\u0430 \u044F
    \u0431\u044B\u043B \u201C\u0434\u044F\u0434\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0443\u043C\u0435\u0435\u0442 \u0434\u0435\u043B\u0430\u0442\u044C \u0432\u0441\u0451\u201D."

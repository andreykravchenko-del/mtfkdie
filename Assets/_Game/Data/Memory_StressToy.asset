  - "\u041F\u0440\u043E\u0441\u0442\u043E \u0438\u0433\u0440\u0443\u0448\u043A\u0430."
  - "\u041D\u0430\u0434\u043E \u0432\u044B\u0442\u0430\u0449\u0438\u0442\u044C \u043F\u0438\u0449\u0430\u043B\u043A\u0443."
  memoryImage: {fileID: 21300000, guid: 353b9ac54c369c34a8ff6f680f0aeb34, type: 3}
  memoryText: "\u0412 \u043C\u0438\u043D\u0443\u0442\u044B \u043E\u0442\u0447\u0430\u044F\u043D\u0438\u044F
    \u043C\u0435\u043D\u044F \u0441\u043F\u0430\u0441\u0430\u043B \u043C\u043E\u0439
    \u043A\u043E\u0442 \u041B\u0443\u043A\u0441\u043E\u0440, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u044F \u043C\u043E\u0433 \u0433\u043B\u0430\u0434\u0438\u0442\u044C \u0438 \u0442\u044B,
    \u0438\u0433\u0440\u0443\u0448\u043A\u0430-\u0430\u043D\u0442\u0438\u0441\u0442\u0440\u0435\u0441\u0441
    \u0412\u0438\u0442\u0451\u043A."

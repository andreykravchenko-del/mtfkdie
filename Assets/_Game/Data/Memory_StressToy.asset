  displayName: "\u0418\u0433\u0440\u0443\u0448\u043A\u0430-\u0430\u043D\u0442\u0438\u0441\u0442\u0440\u0435\u0441\u0441"
  description: "\u0414\u043E\u0431\u0440\u043E\u0442\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u043D\u043D\u0430\u044F

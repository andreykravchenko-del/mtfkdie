  displayName: "\u041C\u0430\u0433\u043D\u0438\u0442 \u043D\u0430 \u0445\u043E\u043B\u043E\u0434\u0438\u043B\u044C\u043D\u0438\u043A\u0435"
  description: "\u041C\u0430\u0433\u043D\u0438\u0442 \u0438\u0437 \u043F\u043E\u0435\u0437\u0434\u043A\u0438.
    \u041C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u044F\u043A\u043E\u0440\u044C
    \u0445\u043E\u0440\u043E\u0448\u0435\u0433\u043E \u0434\u043D\u044F."
  kind: 0
  significant: 1
  rememberHope: 2
  rememberDespair: 0
  forgetHope: 0
  forgetDespair: 1
  captureDuration: 3
  captureComments:
  - "\u041C\u044B \u0442\u0430\u043C \u0431\u044B\u043B\u0438."
  - "\u041F\u0443\u0441\u0442\u044C \u0445\u0440\u0430\u043D\u0438\u0442."
  - "\u0422\u0451\u043F\u043B\u043E\u0435 \u043C\u0435\u0441\u0442\u043E."
  memoryImage: {fileID: 21300000, guid: 628076e135f6c6b4ea66ec117dc937c8, type: 3}
  memoryText: "\u0414\u0430\u0436\u0435 \u043D\u0435 \u0432\u0435\u0440\u0438\u0442\u0441\u044F,
    \u0447\u0442\u043E \u044F \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u043B\u0441\u044F
    \u043F\u043E\u0435\u0445\u0430\u0442\u044C \u0442\u0430\u043A \u0434\u0430\u043B\u0435\u043A\u043E.
    \u0418 \u043D\u0435 \u043F\u043E\u0436\u0430\u043B\u0435\u043B. \"+ \u0412\u0430\u0439\u0431\",
    \u2014 \u043A\u0430\u043A \u0431\u044B \u0441\u043A\u0430\u0437\u0430\u043B \u043C\u043E\u0439
    \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u043A."

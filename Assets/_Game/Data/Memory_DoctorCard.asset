  memoryText: "\u041E\u0434\u043D\u0430\u0436\u0434\u044B \u044F \u043F\u0440\u0438\u0448\u0435\u043B
    \u0431\u0435\u0437 \u0437\u0430\u043F\u0438\u0441\u0438. \u041C\u0435\u043D\u044F
    \u0445\u0432\u0430\u0442\u0438\u043B\u043E \u043D\u0430 15 \u043C\u0438\u043D\u0443\u0442

  memoryImage: {fileID: 21300000, guid: 4cc53893b93de0841830525b72d94c04, type: 3}
  memoryText: "\u0421 \u044D\u0442\u043E\u0433\u043E \u043C\u043E\u043C\u0435\u043D\u0442\u0430
    \u044F \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B \u0436\u0438\u0442\u044C
    \u0438 \u043D\u0430\u0447\u0430\u043B \u0432\u044B\u0436\u0438\u0432\u0430\u0442\u044C.
    \u0418 \u044D\u0442\u043E\u043C\u0443 \u0441\u0442\u0430\u0440\u0430\u043B\u0438\u0441\u044C
    \u043F\u043E\u043C\u0435\u0448\u0430\u0442\u044C \u043A\u0430\u0436\u0434\u044B\u0439
    \u0431\u043E\u0436\u0438\u0439 \u0434\u0435\u043D\u044C \r\n"

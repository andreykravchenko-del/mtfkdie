  memoryText: "\u042F \u0442\u0430\u043A \u043B\u044E\u0431\u0438\u043B \u044D\u0442\u0438
    \u0432\u0435\u0447\u0435\u0440\u0430, \u043A\u043E\u0433\u0434\u0430 \u043C\u043E\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u0437\u0430\u0431\u044B\u0442\u044C\u0441\u044F \u0438
    \u0441\u0442\u0430\u0442\u044C \u0442\u0435\u043C, \u0443 \u043A\u043E\u0433\u043E
